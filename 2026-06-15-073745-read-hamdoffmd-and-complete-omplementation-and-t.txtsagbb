      1192 +/// Compute sha256(vmlinuz || initrd) and patch the `.origin`
           + file's                                                      
      1193 +/// `boot_digest = …` line. `bootc status` uses this digest t
           +o set the soft                                               
      1194 +/// reboot capability; without it, status bails with         
      1195 +/// "Could not find boot digest for deployment".             
      1196 +fn patch_origin_boot_digest(verity: &VerityDigest, vmlinuz: &
           +Path, initrd: &Path) -> Result<()> {                         
      1197 +    use sha2::{Digest, Sha256};                              
      1198 +    let mut hasher = Sha256::new();                          
      1199 +    let v = fs::read(vmlinuz)                                
      1200 +        .with_context(|| format!("reading vmlinuz {}", vmlinu
           +z.display()))?;                                              
      1201 +    let i = fs::read(initrd)                                 
      1202 +        .with_context(|| format!("reading initrd {}", initrd.
           +display()))?;                                                
      1203 +    hasher.update(&v);                                       
      1204 +    hasher.update(&i);                                       
      1205 +    let digest = hex::encode(hasher.finalize());             
      1206 +                                                             
      1207 +    let origin_path = Path::new("/sysroot/state/deploy")     
      1208 +        .join(verity.as_hex())                               
      1209 +        .join(format!("{}.origin", verity.as_hex()));        
      1210 +    let text = fs::read_to_string(&origin_path)              
      1211 +        .with_context(|| format!("reading origin {}", origin_
           +path.display()))?;                                           
      1212 +    let mut out = String::with_capacity(text.len() + digest.l
           +en());                                                       
      1213 +    let mut replaced = false;                                
      1214 +    for line in text.lines() {                               
      1215 +        if line.starts_with("boot_digest") {                 
      1216 +            out.push_str(&format!("boot_digest = {}\n", diges
           +t));                                                         
      1217 +            replaced = true;                                 
      1218 +        } else {                                             
      1219 +            out.push_str(line);                              
      1220 +            out.push('\n');                                  
      1221 +        }                                                    
      1222 +    }                                                        
      1223 +    if !replaced {                                           
      1224 +        out.push_str(&format!("boot_digest = {}\n", digest));
      1225 +    }                                                        
      1226 +    fs::write(&origin_path, out)                             
      1227 +        .with_context(|| format!("writing patched origin {}",
           + origin_path.display()))?;                                   
      1228 +    println!("[phase5] patched origin boot_digest = {}", dige
           +st);                                                         
      1229 +    Ok(())                                                   
      1230 +}                                                            
