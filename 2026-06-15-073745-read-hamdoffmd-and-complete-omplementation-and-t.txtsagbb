      155      Ok(())
      156  }
      157  
      158 +/// Union-merge an identity-DB file by colon-delimited first f
          +ield.                                                         
      159 +/// `current` lines come first (verbatim, preserving order and
          + state); any line                                             
      160 +/// from `new` whose first field isn't already represented get
          +s appended.                                                   
      161 +/// machine-id is opaque — return current as-is.              
      162 +fn merge_identity_db(rel_path: &str, current: Option<&[u8]>, n
          +ew: Option<&[u8]>) -> Option<Vec<u8>> {                       
      163 +    if rel_path == "machine-id" {                             
      164 +        return current.map(|s| s.to_vec()).or_else(|| new.map(
          +|s| s.to_vec()));                                             
      165 +    }                                                         
      166 +    let cur_text = match current {                            
      167 +        Some(c) => std::str::from_utf8(c).ok()?,              
      168 +        None => return new.map(|s| s.to_vec()),               
      169 +    };                                                        
      170 +    let new_text = match new {                                
      171 +        Some(n) => std::str::from_utf8(n).ok()?,              
      172 +        None => return Some(cur_text.as_bytes().to_vec()),    
      173 +    };                                                        
      174 +    let key_of = |line: &str| line.split(':').next().unwrap_or
          +("").to_string();                                             
      175 +    let mut keys: std::collections::HashSet<String> = std::col
          +lections::HashSet::new();                                     
      176 +    let mut out = String::with_capacity(cur_text.len() + new_t
          +ext.len());                                                   
      177 +    for line in cur_text.lines() {                            
      178 +        if !line.is_empty() {                                 
      179 +            keys.insert(key_of(line));                        
      180 +        }                                                     
      181 +        out.push_str(line);                                   
      182 +        out.push('\n');                                       
      183 +    }                                                         
      184 +    for line in new_text.lines() {                            
      185 +        if line.is_empty() {                                  
      186 +            continue;                                         
      187 +        }                                                     
      188 +        let k = key_of(line);                                 
      189 +        if !keys.contains(&k) {                               
      190 +            out.push_str(line);                               
      191 +            out.push('\n');                                   
      192 +            keys.insert(k);                                   
      193 +        }                                                     
      194 +    }                                                         
      195 +    Some(out.into_bytes())                                    
      196 +}                                                             
      197 +                                                              
