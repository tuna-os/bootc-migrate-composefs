      142 +/// Walk `etc_dir` and remove any symlink whose target points 
          +under `/usr/*` but                                            
      143 +/// does not exist relative to `target_root`. Returns the numb
          +er of links removed.                                          
      144 +///                                                           
      145 +/// Why: the 3-way merge brings forward enablement symlinks fr
          +om the source OS's                                            
      146 +/// /etc (e.g. /etc/systemd/system/dbus.service → /usr/lib/sys
          +temd/system/dbus-broker.service).                             
      147 +/// If the target image doesn't ship the underlying unit, the 
          +symlink dangles                                               
      148 +/// after pivot and systemd reports "Failed to load configurat
          +ion: No such file                                             
      149 +/// or directory" — which cascades through dbus → polkit → log
          +ind → sshd.                                                   
      150 +pub fn prune_dangling_usr_symlinks(etc_dir: &Path, target_root
          +: &Path) -> Result<usize> {                                   
      151 +    let mut removed = 0usize;                                 
      152 +    prune_recursive(etc_dir, target_root, &mut removed)?;     
      153 +    Ok(removed)                                               
      154 +}                                                             
      155 +                                                              
      156 +fn prune_recursive(dir: &Path, target_root: &Path, removed: &m
          +ut usize) -> Result<()> {                                     
      157 +    for entry in fs::read_dir(dir)? {                         
      158 +        let entry = entry?;                                   
      159 +        let path = entry.path();                              
      160 +        let ft = entry.file_type()?;                          
      161 +        if ft.is_symlink() {                                  
      162 +            let target = match fs::read_link(&path) {         
      163 +                Ok(t) => t,                                   
      164 +                Err(_) => continue,                           
      165 +            };                                                
      166 +            let target_str = target.to_string_lossy();        
      167 +            if !target_str.starts_with("/usr/") {             
      168 +                continue;                                     
      169 +            }                                                 
      170 +            // Strip leading slash and resolve against target_
          +root.                                                         
      171 +            let rel = target_str.trim_start_matches('/');     
      172 +            let resolved = target_root.join(rel);             
      173 +            // symlink_metadata is fine — we only need to know
          + if the path resolves                                         
      174 +            // to something (file, dir, or another symlink tha
          +t exists).                                                    
      175 +            if fs::metadata(&resolved).is_err() {             
      176 +                eprintln!(                                    
      177 +                    "[phase4] pruning dangling /etc symlink: {
          +} -> {} (not in target /usr)",                                
      178 +                    path.display(),                           
      179 +                    target_str                                
      180 +                );                                            
      181 +                fs::remove_file(&path).with_context(|| {      
      182 +                    format!("failed to remove dangling symlink
          + {}", path.display())                                         
      183 +                })?;                                          
      184 +                *removed += 1;                                
      185 +            }                                                 
      186 +        } else if ft.is_dir() {                               
      187 +            prune_recursive(&path, target_root, removed)?;    
      188 +        }                                                     
      189 +    }                                                         
      190 +    Ok(())                                                    
      191 +}                                                             
      192 +                                                              
